---
---
<section class="fs-hero">
  <div class="fs-hero-grid">
    <div class="fs-hero-left">
      <div class="fs-eyebrow-pill">
        <span class="fs-dot"></span>
        v1.1.1 · MIT · works with any A2A agent
      </div>
      <h1 class="fs-h1">
        Steroids<br />
        for <span class="fs-h1-accent">AI&nbsp;coding</span>.
      </h1>
      <p class="fs-hero-sub">
        Your laptop, desktop, and EC2 — <strong>all running Claude&nbsp;Code, Codex, and Aider in parallel on the same repo.</strong> One command plans the work. Every machine takes a mission. GitHub is the only message bus.
      </p>
      <div class="fs-cta-row">
        <a class="fs-btn fs-btn-primary" href="/getting-started/">
          Get started
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
        </a>
        <a class="fs-btn fs-btn-ghost" href="#how-it-works">▶ Watch how it works</a>
      </div>
      <div class="fs-install">
        <span class="fs-install-prompt">$</span>
        <span class="fs-install-cmd">npx fleetspark init</span>
        <span class="fs-install-copy" id="fs-hero-copy">copy</span>
      </div>
    </div>
    <div class="fs-hero-right">
      <svg viewBox="0 0 440 320" class="fs-orbit" id="fs-orbit">
        <defs>
          <radialGradient id="fs-orbit-glow" cx="0.5" cy="0.5" r="0.5">
            <stop offset="0" stop-color="rgba(250,204,21,0.25)"></stop>
            <stop offset="1" stop-color="rgba(250,204,21,0)"></stop>
          </radialGradient>
        </defs>
        <circle cx="220" cy="150" r="120" fill="url(#fs-orbit-glow)"></circle>
        <g id="fs-orbit-links" stroke="#1f2840" stroke-width="1" stroke-dasharray="3 5" fill="none"></g>
        <g id="fs-orbit-packets"></g>
        <g id="fs-orbit-nodes"></g>
        <circle cx="220" cy="150" r="22" fill="#0a0e17" stroke="var(--fs-signal)" stroke-width="1.4"></circle>
        <text x="220" y="154" text-anchor="middle" fill="var(--fs-signal)" font-size="10" font-family="var(--fs-mono)" font-weight="700">GH</text>
      </svg>
      <div class="fs-hero-stats">
        <div class="fs-hero-stat"><span class="fs-mono">missions</span><b>3</b></div>
        <div class="fs-hero-stat"><span class="fs-mono">ships</span><b>3</b></div>
        <div class="fs-hero-stat"><span class="fs-mono">agents</span><b>3</b></div>
        <div class="fs-hero-stat"><span class="fs-mono">wall time</span><b style="color: var(--fs-spark)">23 min</b></div>
      </div>
    </div>
  </div>
</section>

<style>
  .fs-hero {
    max-width: 1200px;
    margin: 0 auto;
    padding: 56px 24px 40px;
    position: relative;
  }
  .fs-hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 48px;
    align-items: center;
  }
  @media (max-width: 960px) {
    .fs-hero-grid { grid-template-columns: 1fr; gap: 32px; }
  }
  .fs-eyebrow-pill {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 6px 12px;
    border: 1px solid var(--fs-line-2);
    border-radius: 999px;
    background: rgba(56, 189, 248, 0.04);
    font-family: var(--fs-mono);
    font-size: 12px;
    color: var(--fs-signal);
    margin-bottom: 22px;
  }
  .fs-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--fs-signal);
    box-shadow: 0 0 10px var(--fs-signal);
    animation: fs-pulse 1.6s ease-in-out infinite;
  }
  @keyframes fs-pulse {
    0%, 100% { opacity: 0.4; transform: scale(0.9); }
    50% { opacity: 1; transform: scale(1.1); }
  }
  .fs-h1 {
    font-family: var(--fs-display);
    font-size: clamp(40px, 6.2vw, 76px);
    line-height: 0.98;
    letter-spacing: -0.035em;
    font-weight: 700;
    margin: 0 0 24px;
    color: var(--fs-text);
  }
  .fs-h1-accent {
    background: linear-gradient(135deg, var(--fs-spark) 0%, #fde047 35%, var(--fs-signal) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .fs-hero-sub {
    font-size: 18px;
    line-height: 1.6;
    color: var(--fs-muted);
    max-width: 540px;
    margin: 0 0 28px;
  }
  .fs-hero-sub strong { color: var(--fs-text); font-weight: 600; }
  .fs-cta-row { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 28px; }
  .fs-install {
    display: inline-flex; align-items: center; gap: 12px;
    font-family: var(--fs-mono);
    font-size: 13px;
    color: var(--fs-muted);
    padding: 10px 14px;
    border: 1px dashed var(--fs-line-2);
    border-radius: 10px;
    background: rgba(255,255,255,0.02);
  }
  .fs-install-prompt { color: var(--fs-spark); }
  .fs-install-cmd { color: var(--fs-text); }
  .fs-install-copy { margin-left: 8px; font-size: 11px; color: var(--fs-muted-2); border-left: 1px solid var(--fs-line); padding-left: 10px; cursor: pointer; }
  .fs-install-copy:hover { color: var(--fs-signal); }
  .fs-hero-right { display: grid; gap: 18px; }
  .fs-orbit {
    width: 100%; height: auto; aspect-ratio: 440/320;
    border: 1px solid var(--fs-line);
    border-radius: 18px;
    background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(250,204,21,0.05), transparent 70%), linear-gradient(180deg, var(--fs-panel), var(--fs-panel-2));
  }
  .fs-hero-stats {
    display: grid; grid-template-columns: 1fr 1fr; gap: 0;
    border: 1px solid var(--fs-line);
    border-radius: 14px;
    background: var(--fs-panel);
    overflow: hidden;
  }
  .fs-hero-stat {
    display: flex; justify-content: space-between; align-items: baseline;
    padding: 14px 16px;
    border-right: 1px solid var(--fs-line);
    border-bottom: 1px solid var(--fs-line);
    font-size: 12px;
    color: var(--fs-muted-2);
  }
  .fs-hero-stat:nth-child(2n) { border-right: none; }
  .fs-hero-stat:nth-last-child(-n+2) { border-bottom: none; }
  .fs-hero-stat b {
    font-family: var(--fs-display);
    font-size: 22px; font-weight: 700;
    color: var(--fs-text);
    letter-spacing: -0.02em;
  }
</style>

<script is:inline>
(() => {
  const svg = document.getElementById('fs-orbit');
  if (!svg) return;
  const nodes = [
    { x: 60,  y: 70,  label: 'laptop',  color: '#facc15' },
    { x: 320, y: 50,  label: 'desktop', color: '#c084fc' },
    { x: 380, y: 220, label: 'EC2',     color: '#38bdf8' },
    { x: 80,  y: 240, label: 'CI',      color: '#34d399' }
  ];
  const hub = { x: 220, y: 150 };
  const linksG = svg.querySelector('#fs-orbit-links');
  const nodesG = svg.querySelector('#fs-orbit-nodes');
  const packetsG = svg.querySelector('#fs-orbit-packets');
  nodes.forEach((n, i) => {
    const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
    line.setAttribute('x1', n.x); line.setAttribute('y1', n.y);
    line.setAttribute('x2', hub.x); line.setAttribute('y2', hub.y);
    linksG.appendChild(line);
    const c = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
    c.setAttribute('cx', n.x); c.setAttribute('cy', n.y); c.setAttribute('r', '14');
    c.setAttribute('fill', '#0a0e17'); c.setAttribute('stroke', n.color); c.setAttribute('stroke-width', '1.2');
    nodesG.appendChild(c);
    const t = document.createElementNS('http://www.w3.org/2000/svg', 'text');
    t.setAttribute('x', n.x); t.setAttribute('y', n.y + 4);
    t.setAttribute('text-anchor', 'middle'); t.setAttribute('fill', n.color);
    t.setAttribute('font-size', '9'); t.setAttribute('font-family', 'JetBrains Mono, monospace');
    t.setAttribute('font-weight', '700'); t.textContent = n.label;
    nodesG.appendChild(t);
    const p = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
    p.setAttribute('r', '3'); p.setAttribute('fill', n.color);
    packetsG.appendChild(p);
    n._packet = p;
  });
  let start = null;
  function tick(now) {
    if (!start) start = now;
    const t = (now - start) / 1000;
    nodes.forEach((n, i) => {
      const phase = (t * 0.6 + i * 0.25) % 1;
      const dx = hub.x - n.x, dy = hub.y - n.y;
      n._packet.setAttribute('cx', n.x + dx * phase);
      n._packet.setAttribute('cy', n.y + dy * phase);
      n._packet.setAttribute('opacity', 1 - phase);
    });
    requestAnimationFrame(tick);
  }
  requestAnimationFrame(tick);

  // Copy
  const copy = document.getElementById('fs-hero-copy');
  if (copy) copy.addEventListener('click', () => {
    navigator.clipboard?.writeText('npx fleetspark init');
    copy.textContent = 'copied'; setTimeout(() => copy.textContent = 'copy', 1200);
  });
})();
</script>
