---
---
<section class="hero">
  <div class="hero-glow" aria-hidden="true"></div>
  <div class="hero-content">
    <div class="brand-mark">⚡ Fleet</div>

    <h1>
      Multi-machine. Multi-LLM.<br/>
      <span class="gradient-text">One fleet.</span>
    </h1>

    <p class="subtitle">
      Fleet runs Claude Code, Gemini, Codex, Aider, and 4 more AI agents
      in parallel — across your laptop, desktop, and servers simultaneously.
      One command to plan. Every machine working. All results merged automatically.
    </p>

    <div class="dimensions">
      <div class="dimension">
        <span class="dim-icon">🖥️</span>
        <div>
          <span class="dim-label">Multi-machine</span>
          <span class="dim-desc">Laptop · Desktop · Servers · CI runners</span>
        </div>
      </div>
      <div class="dim-separator">×</div>
      <div class="dimension">
        <span class="dim-icon">🤖</span>
        <div>
          <span class="dim-label">Multi-LLM</span>
          <span class="dim-desc">Claude · Gemini · Codex · Aider · 4 more</span>
        </div>
      </div>
    </div>

    <div class="audience-pills">
      <span class="pill">Solo developers</span>
      <span class="pill">Small teams</span>
      <span class="pill">Any Git repo</span>
      <span class="pill">8 AI adapters</span>
    </div>

    <div class="value-metric">
      <span class="metric-highlight">3 machines. 6 missions. 23 minutes.</span>
      <span class="metric-follow">What used to take a full day.</span>
    </div>

    <div class="hero-ctas">
      <a href="/getting-started/" class="cta-solid">
        Get Started
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href="/getting-started/#demo" class="cta-outline-demo">
        ▶ Try the 30s demo
      </a>
      <a href="https://github.com/fleetSpark/fleet" class="cta-outline" target="_blank" rel="noopener">
        <img
          src="https://img.shields.io/github/stars/fleetSpark/fleet?style=social"
          alt="GitHub stars"
          width="84"
          height="20"
          loading="eager"
        />
        Star on GitHub
      </a>
    </div>

    <p class="install-hint"><code>npx fleetspark demo</code> — no setup, no account, 30 seconds</p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    text-align: center;
    padding: 6rem 1.5rem 5rem;
    max-width: 56rem;
    margin: 0 auto;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    top: -20%;
    left: 50%;
    translate: -50% 0;
    width: 140%;
    height: 100%;
    background:
      radial-gradient(ellipse 60% 50% at 40% 40%, rgba(250, 204, 21, 0.09) 0%, transparent 70%),
      radial-gradient(ellipse 60% 50% at 60% 60%, rgba(56, 189, 248, 0.07) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .brand-mark {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #64748b;
    margin-bottom: 1.5rem;
  }

  .hero h1 {
    font-size: clamp(2.5rem, 6vw, 4.25rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: #f1f5f9;
    margin: 0 0 1.5rem;
  }

  .gradient-text {
    display: inline;
    background: linear-gradient(135deg, #facc15 0%, #38bdf8 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.75;
    color: #94a3b8;
    max-width: 42rem;
    margin: 0 auto 2rem;
  }

  /* Dimensions row */
  .dimensions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    margin: 0 auto 2rem;
    flex-wrap: wrap;
  }

  .dimension {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid #1e2d45;
    border-radius: 10px;
    padding: 0.75rem 1.25rem;
  }

  .dim-icon {
    font-size: 1.4rem;
    line-height: 1;
  }

  .dim-label {
    display: block;
    font-size: 0.9rem;
    font-weight: 700;
    color: #f1f5f9;
    line-height: 1.2;
  }

  .dim-desc {
    display: block;
    font-size: 0.75rem;
    color: #64748b;
    line-height: 1.4;
    margin-top: 0.1rem;
  }

  .dim-separator {
    font-size: 1.5rem;
    font-weight: 800;
    color: #facc15;
    line-height: 1;
  }

  /* Audience pills */
  .audience-pills {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
  }

  .pill {
    font-size: 0.8rem;
    font-weight: 500;
    color: #94a3b8;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid #1e2d45;
    border-radius: 999px;
    padding: 0.3rem 0.9rem;
    letter-spacing: 0.01em;
  }

  /* Value metric */
  .value-metric {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    margin: 0 auto 2.75rem;
    padding: 1rem 1.75rem;
    border-radius: 0.75rem;
    border: 1px solid rgba(250, 204, 21, 0.14);
    background: rgba(250, 204, 21, 0.04);
    max-width: 26rem;
  }

  .metric-highlight {
    font-size: 1.1rem;
    font-weight: 700;
    color: #facc15;
    letter-spacing: -0.01em;
  }

  .metric-follow {
    font-size: 0.9rem;
    color: #64748b;
  }

  /* CTAs */
  .hero-ctas {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.875rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .hero-ctas a {
    text-decoration: none;
    font-weight: 600;
    transition: all 0.2s ease;
  }

  .cta-solid {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 1.75rem;
    border-radius: 0.5rem;
    font-size: 1rem;
    background: linear-gradient(135deg, #facc15, #f59e0b);
    color: #0a0e17;
    box-shadow: 0 0 20px rgba(250, 204, 21, 0.2);
  }

  .cta-solid:hover {
    background: linear-gradient(135deg, #fde047, #facc15);
    box-shadow: 0 0 30px rgba(250, 204, 21, 0.35);
    translate: 0 -1px;
  }

  .cta-outline-demo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 1.5rem;
    border-radius: 0.5rem;
    font-size: 0.95rem;
    border: 1px solid rgba(56, 189, 248, 0.3);
    color: #38bdf8;
    background: rgba(56, 189, 248, 0.05);
  }

  .cta-outline-demo:hover {
    border-color: #38bdf8;
    background: rgba(56, 189, 248, 0.1);
    translate: 0 -1px;
  }

  .cta-outline {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 1.25rem;
    border-radius: 0.5rem;
    font-size: 0.9rem;
    border: 1px solid #334155;
    color: #94a3b8;
  }

  .cta-outline img { display: block; }

  .cta-outline:hover {
    border-color: #475569;
    color: #f1f5f9;
    translate: 0 -1px;
  }

  .install-hint {
    font-size: 0.82rem;
    color: #475569;
    margin: 0;
  }

  .install-hint code {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    color: #64748b;
    background: rgba(255,255,255,0.04);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
  }

  @media (max-width: 768px) {
    .hero { padding: 4rem 1rem 3rem; }
    .hero-ctas { flex-direction: column; gap: 0.625rem; }
    .value-metric { max-width: 100%; }
    .audience-pills { gap: 0.375rem; }
    .dimensions { flex-direction: column; gap: 0.75rem; }
    .dim-separator { transform: rotate(90deg); }
  }
</style>
