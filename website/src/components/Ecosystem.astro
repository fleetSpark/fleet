---
const plugin = {
  name: 'drsti-dev-flow',
  npm: '@fleetspark/plugin-drsti-dev-flow',
  description: 'Governance plugin for AI-assisted development. Adds maturity levels, workstream tracking, and structured review gates (spec → implement → peer-review) to any fleet run — with enforceable pre-mission and pre-merge hooks.',
  tags: ['Maturity levels L1–L4', 'Workstream state', 'Scope conflict checks', 'Level 4 review gates', 'Pre-mission + pre-merge hooks'],
  link: '/ecosystem/',
  source: 'https://drsti.ai',
};
---

<div class="landing-section ecosystem-section">
  <div class="ecosystem-label">
    <span class="pill">Ecosystem</span>
  </div>

  <h2>Governance for critical work</h2>
  <p class="subtitle">
    FleetSpark ships the execution layer. For regulated or team-critical work that needs
    structured review gates and workstream tracking, the ecosystem has you covered.
  </p>

  <div class="plugin-card">
    <div class="plugin-header">
      <div class="plugin-name-row">
        <span class="plugin-name">{plugin.name}</span>
        <span class="plugin-npm">{plugin.npm}</span>
      </div>
      <p class="plugin-desc">{plugin.description}</p>
    </div>
    <div class="plugin-tags">
      {plugin.tags.map((tag) => (
        <span class="plugin-tag">{tag}</span>
      ))}
    </div>
    <div class="plugin-footer-row">
      <div class="plugin-source">
        Built by <a href={plugin.source} target="_blank" rel="noopener">drsti.ai</a>
      </div>
      <a href={plugin.link} class="plugin-link">Learn more →</a>
    </div>
  </div>

  <p class="plugin-coming-soon">
    Install in one command: <code>fleet plugin install @fleetspark/plugin-drsti-dev-flow</code>
    — then run <code>fleet run --template drsti-dev-flow</code> to get full gate enforcement on your next feature.
    <a href="/ecosystem/">See the full plugin architecture →</a>
  </p>
</div>

<style>
  .ecosystem-section {
    background: #0a0f1e;
    border-top: 1px solid #1a2035;
  }

  .ecosystem-label {
    margin-bottom: 1rem;
  }

  .pill {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: #facc15;
    background: rgba(250, 204, 21, 0.08);
    border: 1px solid rgba(250, 204, 21, 0.2);
    border-radius: 999px;
    padding: 0.25rem 0.85rem;
  }

  .ecosystem-section h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: #f1f5f9;
    margin: 0 0 0.75rem;
  }

  .ecosystem-section .subtitle {
    color: #94a3b8;
    font-size: 1rem;
    max-width: 44rem;
    line-height: 1.65;
    margin-bottom: 2rem;
  }

  .plugin-card {
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid #1e2d45;
    border-radius: 14px;
    padding: 2rem;
    max-width: 52rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    transition: border-color 0.2s;
  }

  .plugin-card:hover {
    border-color: #334155;
  }

  .plugin-name-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }

  .plugin-name {
    font-size: 1.15rem;
    font-weight: 700;
    color: #f1f5f9;
  }

  .plugin-npm {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.78rem;
    color: #64748b;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid #1e2d45;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }

  .plugin-desc {
    font-size: 0.9rem;
    color: #94a3b8;
    line-height: 1.65;
    margin: 0;
  }

  .plugin-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .plugin-tag {
    font-size: 0.78rem;
    font-weight: 500;
    color: #cbd5e1;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid #1e2d45;
    border-radius: 999px;
    padding: 0.25rem 0.75rem;
  }

  .plugin-footer-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid #1a2035;
  }

  .plugin-source {
    font-size: 0.85rem;
    color: #64748b;
  }

  .plugin-source a {
    color: #94a3b8;
    text-decoration: none;
  }

  .plugin-source a:hover {
    color: #f1f5f9;
  }

  .plugin-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: #facc15;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .plugin-link:hover { opacity: 0.8; }

  .plugin-coming-soon {
    font-size: 0.82rem;
    color: #475569;
    margin-top: 1.25rem;
    max-width: 52rem;
    line-height: 1.6;
  }

  .plugin-coming-soon a {
    color: #64748b;
    text-decoration: none;
  }

  .plugin-coming-soon a:hover { color: #94a3b8; }
</style>
